{
  "root": true,
  "env": {
    "browser": true,
    "node": true,
    "es2022": true
  },
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": [
    "@typescript-eslint"
  ],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "ignorePatterns": [
    "node_modules/",
    ".webpack/",
    "out/",
    "dist/"
  ],
  "overrides": [
    {
      "files": [
        "forge.config.ts",
        "webpack.*.ts",
        "src/index.ts"
      ],
      "rules": {
        "@typescript-eslint/no-require-imports": "off"
      }
    }
  ]
}